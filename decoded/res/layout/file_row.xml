<?xml version="1.0" encoding="utf-8"?>
<LinearLayout android:orientation="vertical" android:padding="10.0dip" android:layout_width="fill_parent" android:layout_height="fill_parent"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout android:orientation="horizontal" android:layout_width="fill_parent" android:layout_height="wrap_content">
        <TextView android:textStyle="bold" android:id="@id/frowTxtTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" />
        <TextView android:gravity="right" android:layout_gravity="right" android:id="@id/frowTxtTime" android:layout_width="fill_parent" android:layout_height="wrap_content" />
    </LinearLayout>
    <LinearLayout android:orientation="horizontal" android:layout_width="fill_parent" android:layout_height="wrap_content">
        <TextView android:id="@id/frowTxtUploaded" android:layout_width="wrap_content" android:layout_height="wrap_content" />
        <TextView android:gravity="right" android:layout_gravity="right" android:id="@id/frowTxtKmMax" android:layout_width="fill_parent" android:layout_height="wrap_content" />
    </LinearLayout>
</LinearLayout>
