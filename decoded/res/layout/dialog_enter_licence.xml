<?xml version="1.0" encoding="utf-8"?>
<ScrollView android:background="@color/backgray2" android:layout_width="fill_parent" android:layout_height="fill_parent"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout android:orientation="vertical" android:padding="8.0dip" android:layout_width="fill_parent" android:layout_height="wrap_content">
        <TextView android:textColor="@color/black" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/enter_licence_desc" />
        <EditText android:id="@id/licence_key" android:layout_width="fill_parent" android:layout_height="wrap_content" android:inputType="textCapCharacters">
            <requestFocus />
        </EditText>
        <Button android:id="@id/butOk" android:layout_width="fill_parent" android:layout_height="wrap_content" android:text="@string/ok" />
    </LinearLayout>
</ScrollView>
